# TriMCP — defaults for Docker Compose (internal service hostnames).
# Copy to deploy/compose.stack.env (or use bootstrap-generated overlay):
#   cp deploy/compose.stack.env.example deploy/compose.stack.env
#   python scripts/bootstrap-compose-secrets.py
#
# PG_DSN and MinIO credentials are injected in compose.yml so they stay in
# sync with POSTGRES_PASSWORD / MINIO_ROOT_* interpolation.

MONGO_URI=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

TRIMCP_LLM_PROVIDER=local-cognitive-model
TRIMCP_COGNITIVE_BASE_URL=http://cognitive:11435

TRIMCP_MASTER_KEY=REPLACE_ME_RUN_bootstrap_compose_secrets_32CHARS_MIN
TRIMCP_API_KEY=REPLACE_ME_RUN_bootstrap_compose_secrets

TRIMCP_ADMIN_USERNAME=admin
TRIMCP_ADMIN_PASSWORD=REPLACE_ME_RUN_bootstrap_compose_secrets

TRIMCP_JWT_SECRET=REPLACE_ME_RUN_bootstrap_compose_secrets_32CHARS_MIN
TRIMCP_A2A_URL=http://localhost:8004

DROPBOX_APP_SECRET=REPLACE_ME_RUN_bootstrap_compose_secrets
GRAPH_CLIENT_STATE=REPLACE_ME_RUN_bootstrap_compose_secrets
DRIVE_CHANNEL_TOKEN=REPLACE_ME_RUN_bootstrap_compose_secrets

BRIDGE_WEBHOOK_BASE_URL=http://localhost

PG_MIN_POOL=1
PG_MAX_POOL=10
REDIS_MAX_CONNECTIONS=20
REDIS_TTL=3600

GC_INTERVAL_SECONDS=3600
GC_ORPHAN_AGE_SECONDS=300

TRIMCP_QUOTAS_ENABLED=true
BRIDGE_CRON_INTERVAL_MINUTES=45
BRIDGE_RENEWAL_LOOKAHEAD_HOURS=12

# Sleep consolidation (namespaces with metadata.consolidation.enabled=true)
CONSOLIDATION_CRON_INTERVAL_MINUTES=360

# Observability (OTLP + Prometheus)
TRIMCP_OBSERVABILITY_ENABLED=true
TRIMCP_PROMETHEUS_PORT=8000
TRIMCP_OTEL_SERVICE_NAME=trimcp-python
TRIMCP_OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
