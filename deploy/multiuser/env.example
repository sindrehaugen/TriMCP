# Copy to `.env` next to docker-compose.yml (or set TRIMCP_ENV_FILE).
# Values below match trimcp.config defaults, rewritten for in-compose DNS names.

MONGO_URI=mongodb://mongodb:27017
PG_DSN=postgresql://mcp_user:mcp_password@postgres:5432/memory_meta
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=mcp_admin
MINIO_SECRET_KEY=super_secure_minio_password
MINIO_SECURE=false

# Webhook HMAC secrets — replace in production.
DROPBOX_APP_SECRET=change-me
GRAPH_CLIENT_STATE=change-me
DRIVE_CHANNEL_TOKEN=change-me
