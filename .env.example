# ============================================================
# TriMCP v1.0 — environment template
#
# Docker Compose (self-hosted, zero-copy):
#   Root compose loads deploy/compose.stack.env automatically.
#   Optional: create a project `.env` for Compose variable substitution only
#   (POSTGRES_PASSWORD, MINIO_ROOT_*, TRIMCP_A2A_URL, ports).
#
# Host MCP (Cursor / Claude) against a Compose-backed stack:
#   Use the *Host* URLs below (127.0.0.1 + published ports).
#
# NEVER commit a real `.env` to version control.
# ============================================================

# --- Docker Compose interpolation (optional project `.env` beside docker-compose.yml) ---
# POSTGRES_PASSWORD=mcp_password
# MINIO_ROOT_USER=mcp_admin
# MINIO_ROOT_PASSWORD=super_secure_minio_password
# ADMIN_PORT=8003
# A2A_PORT=8004
# WEBHOOK_PORT=8080
# CADDY_HTTP_PORT=80
# COGNITIVE_PORT=11435
# TRIMCP_A2A_URL=http://localhost:8004
# TRIMCP_LLM_PROVIDER=local-cognitive-model
# TRIMCP_COGNITIVE_BASE_URL=http://127.0.0.1:11435

# --- MongoDB ---
# Compose internal: mongodb://mongodb:27017
# Host / MCP against default compose ports:
MONGO_URI=mongodb://127.0.0.1:27017

# --- PostgreSQL + pgvector ---
# Compose internal: postgresql://mcp_user:mcp_password@postgres:5432/memory_meta
# Host / MCP (matches default POSTGRES_PASSWORD in compose):
PG_DSN=postgresql://mcp_user:mcp_password@127.0.0.1:5432/memory_meta

# --- Redis ---
# Compose internal: redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# --- MinIO (compose publishes S3 API as host :9002, console :9003) ---
MINIO_ENDPOINT=127.0.0.1:9002
MINIO_ACCESS_KEY=mcp_admin
MINIO_SECRET_KEY=super_secure_minio_password
MINIO_SECURE=false

# --- Security (rotate for production; stack file has dev placeholders) ---
# TRIMCP_MASTER_KEY: required at process start. Minimum 32 UTF-8 bytes (not just 32 ASCII chars for emoji/passwords). Use e.g. openssl rand -base64 32
TRIMCP_MASTER_KEY=replace-with-32-plus-random-chars-minimum
TRIMCP_API_KEY=replace-with-long-random-api-key
# Admin HTTP replicas: Redis-backed HMAC nonce replay protection (omit for single-instance timestamp-only checks)
# TRIMCP_DISTRIBUTED_REPLAY=true

# Admin UI (HTTP Basic for browser pages)
TRIMCP_ADMIN_USERNAME=admin
TRIMCP_ADMIN_PASSWORD=changeme

# JWT (A2A / protected routes): HS256 secret or set TRIMCP_JWT_PUBLIC_KEY for RS*
TRIMCP_JWT_SECRET=replace-with-jwt-secret-at-least-32-characters

# Public URL for A2A agent card (.well-known); must match how peers reach this host
TRIMCP_A2A_URL=http://localhost:8004

# --- Cognitive / embeddings (D2/D7) ---
TRIMCP_LLM_PROVIDER=local-cognitive-model
TRIMCP_COGNITIVE_BASE_URL=http://127.0.0.1:11435
# TRIMCP_COGNITIVE_EMBEDDING_MODEL=
# TRIMCP_COGNITIVE_API_KEY=

# --- Document bridges + webhooks ---
BRIDGE_WEBHOOK_BASE_URL=http://localhost
DROPBOX_APP_SECRET=change-me
GRAPH_CLIENT_STATE=change-me
DRIVE_CHANNEL_TOKEN=change-me
# GRAPH_BRIDGE_TOKEN=
# GDRIVE_BRIDGE_TOKEN=
# DROPBOX_BRIDGE_TOKEN=

# --- OAuth (set when using connect_bridge / complete_bridge_auth) ---
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=common
# BRIDGE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/bridge/oauth/callback
# GDRIVE_OAUTH_CLIENT_ID=
# GDRIVE_OAUTH_CLIENT_SECRET=

# --- Pools, TTL, GC ---
PG_MIN_POOL=1
PG_MAX_POOL=10
REDIS_MAX_CONNECTIONS=20
REDIS_TTL=3600
GC_INTERVAL_SECONDS=3600
GC_ORPHAN_AGE_SECONDS=300

# --- Quotas ---
TRIMCP_QUOTAS_ENABLED=true

# --- Cron (also set in deploy/compose.stack.env for containers) ---
BRIDGE_CRON_INTERVAL_MINUTES=45
BRIDGE_RENEWAL_LOOKAHEAD_HOURS=12

# --- Embedding batch ---
EMBED_BATCH_CHUNK=64

# --- In-process embedding backend (optional; default uses cognitive HTTP when URL set) ---
# TRIMCP_BACKEND=cpu

# --- Phase 1.2+ LLM keys (BYO) ---
# TRIMCP_OPENAI_API_KEY=
# TRIMCP_ANTHROPIC_API_KEY=
# (see trimcp/config.py for full list)

# --- Re-embedding worker (optional overrides) ---
# REEMBED_BATCH_SIZE=32
# REEMBED_BATCHES_PER_MINUTE=20
# REEMBED_CRON_INTERVAL_MINUTES=60
