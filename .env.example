# ============================================================
# TriMCP v1.0 — environment template
#
# Docker Compose (self-hosted, zero-copy):
#   Root compose loads deploy/compose.stack.env automatically.
#   Optional: create a project `.env` for Compose variable substitution only
#   (POSTGRES_PASSWORD, MINIO_ROOT_*, TRIMCP_A2A_URL, ports).
#
# Host MCP (Cursor / Claude) against a Compose-backed stack:
#   Use the *Host* URLs below (127.0.0.1 + published ports).
#
# NEVER commit a real `.env` to version control.
# ============================================================

# --- Docker Compose interpolation (optional project `.env` beside docker-compose.yml) ---
# POSTGRES_PASSWORD=mcp_password
# MINIO_ROOT_USER=mcp_admin
# MINIO_ROOT_PASSWORD=super_secure_minio_password
# ADMIN_PORT=8003
# A2A_PORT=8004
# WEBHOOK_PORT=8080
# CADDY_HTTP_PORT=80
# COGNITIVE_PORT=11435
# TRIMCP_A2A_URL=http://localhost:8004
# TRIMCP_LLM_PROVIDER=local-cognitive-model
# TRIMCP_COGNITIVE_BASE_URL=http://127.0.0.1:11435

# --- MongoDB ---
# Compose internal: mongodb://mongodb:27017
# Host / MCP against default compose ports:
MONGO_URI=mongodb://127.0.0.1:27017

# --- PostgreSQL + pgvector ---
# Compose internal: postgresql://mcp_user:mcp_password@postgres:5432/memory_meta
# Host / MCP (matches default POSTGRES_PASSWORD in compose):
PG_DSN=postgresql://mcp_user:mcp_password@127.0.0.1:5432/memory_meta

# Integration tests (`pytest -m integration`): isolate from your dev DB if needed.
# TRIMCP_INTEGRATION_PG_DSN=postgresql://mcp_user:mcp_password@127.0.0.1:5432/memory_meta_test
#
# Must match encrypted rows in signing_keys, or integration fixtures skip (unless refresh is on).
# TRIMCP_INTEGRATION_REFRESH_SIGNING_ON_DECRYPT_FAIL=1  # disposable DB only — calls rotate_key
#
# Privilege-layer WORM assertions need a restricted login (Compose default `mcp_user`
# owns tables; `UPDATE ... WHERE FALSE` can succeed — those tests skip unless set):
# PG_DSN_APP=postgresql://trimcp_app:secret@127.0.0.1:5432/memory_meta

# --- Read/Write Split (optional) ---
# When set, read-only queries (GET/search/recall) route to DB_READ_URL.
# Workers and mutations continue to use DB_WRITE_URL (defaults to PG_DSN).
# DB_READ_URL=postgresql://mcp_user:mcp_password@127.0.0.1:5433/memory_meta
# DB_WRITE_URL=postgresql://mcp_user:mcp_password@127.0.0.1:5432/memory_meta
# PG_BOUNCER_URL=postgresql://mcp_user:mcp_password@127.0.0.1:6432/memory_meta

# --- Redis ---
# Compose internal: redis://redis:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# --- MinIO (compose publishes S3 API as host :9002, console :9003) ---
MINIO_ENDPOINT=127.0.0.1:9002
MINIO_ACCESS_KEY=mcp_admin
MINIO_SECRET_KEY=super_secure_minio_password
MINIO_SECURE=false

# --- Security (rotate for production; stack file has dev placeholders) ---
# TRIMCP_MASTER_KEY: required at process start. Minimum 32 UTF-8 bytes (not just 32 ASCII chars for emoji/passwords). Use e.g. openssl rand -base64 32
TRIMCP_MASTER_KEY=replace-with-32-plus-random-chars-minimum
TRIMCP_API_KEY=replace-with-long-random-api-key
# Admin HTTP replicas: Redis-backed HMAC nonce replay protection (omit for single-instance timestamp-only checks)
# TRIMCP_DISTRIBUTED_REPLAY=true

# Admin UI (HTTP Basic for browser pages) + MCP admin tools (Bearer TRIMCP_ADMIN_API_KEY)
# Production checklist (TRIMCP_ENV=production or prod):
#   - Set strong random TRIMCP_API_KEY, TRIMCP_ADMIN_API_KEY, TRIMCP_MASTER_KEY (32+ bytes)
#   - TRIMCP_ADMIN_PASSWORD must be $pbkdf2$... (generate via trimcp auth helpers / deploy script)
#   - TRIMCP_ALLOW_ADMIN_DOTENV_PERSIST=false, TRIMCP_LOAD_DOTENV=false
#   - TRIMCP_ADMIN_OVERRIDE=false, TRIMCP_BYPASS_WORM=false, TRIMCP_BYPASS_RLS=false
#   - Prefer TRIMCP_ADMIN_MTLS_ENABLED=true behind your edge proxy
TRIMCP_ADMIN_USERNAME=admin
TRIMCP_ADMIN_PASSWORD=changeme
TRIMCP_ADMIN_API_KEY=replace-with-long-random-admin-mcp-key
# MCP stdio tenant tools (Cursor/Claude env block — required in production)
TRIMCP_MCP_API_KEY=replace-with-long-random-mcp-tenant-key
# Required in production when TRIMCP_MCP_API_KEY is set — pins stdio MCP tools to one tenant.
TRIMCP_MCP_NAMESPACE_ID=00000000-0000-4000-8000-000000000001
# MPXJ sidecar for .mpp extraction — executable basename must be allowlisted (default: java, python, python3, mpxj-cli)
# TRIMCP_MPXJ_EXTRACTOR=java -jar /opt/mpxj/cli.jar
# TRIMCP_MPXJ_ALLOWED_BINARIES=java,python3
# Migration MCP tools: default disabled in production (TRIMCP_DISABLE_MIGRATION_MCP=true).
# Controlled window only: TRIMCP_ALLOW_MIGRATION_MCP_IN_PROD=true with TRIMCP_DISABLE_MIGRATION_MCP=false
# TRIMCP_DISABLE_MIGRATION_MCP=true
# HTTP admin rate limits (per client IP; in-memory or Redis when engine connected)
# TRIMCP_ADMIN_HTTP_RATE_LIMIT=120
# TRIMCP_ADMIN_HTTP_RATE_PERIOD=60
# TRIMCP_ADMIN_HTTP_SENSITIVE_RATE_LIMIT=30
# TRIMCP_ADMIN_HTTP_SENSITIVE_RATE_PERIOD=60
# Allow Admin UI to write connector/datastore secrets into .env (local dev only; forbidden when ENVIRONMENT=production)
# TRIMCP_ALLOW_ADMIN_DOTENV_PERSIST=true

# JWT (A2A / protected routes): HS256 secret or set TRIMCP_JWT_PUBLIC_KEY for RS*
TRIMCP_JWT_SECRET=replace-with-jwt-secret-at-least-32-characters

# Public URL for A2A agent card (.well-known); must match how peers reach this host
TRIMCP_A2A_URL=http://localhost:8004

# --- Cognitive / embeddings (D2/D7) ---
TRIMCP_LLM_PROVIDER=local-cognitive-model
TRIMCP_COGNITIVE_BASE_URL=http://127.0.0.1:11435
# TRIMCP_COGNITIVE_EMBEDDING_MODEL=
# TRIMCP_COGNITIVE_API_KEY=

# --- Document bridges + webhooks ---
BRIDGE_WEBHOOK_BASE_URL=http://localhost
DROPBOX_APP_SECRET=change-me
GRAPH_CLIENT_STATE=change-me
DRIVE_CHANNEL_TOKEN=change-me
# Webhook receiver hardening (trimcp/webhook_receiver)
# WEBHOOK_MAX_BODY_BYTES=1048576
# WEBHOOK_RATE_LIMIT=120
# WEBHOOK_RATE_PERIOD_SECONDS=60
# WEBHOOK_DEDUP_TTL_SECONDS=86400
# Fail-open dedup when Redis is down (default false — duplicates are skipped instead)
# WEBHOOK_DEDUP_FAIL_OPEN=false
# Set true only when a trusted reverse proxy sets X-Forwarded-For (rate-limit key).
# TRIMCP_WEBHOOK_TRUST_PROXY=false
# GRAPH_BRIDGE_TOKEN=
# GDRIVE_BRIDGE_TOKEN=
# DROPBOX_BRIDGE_TOKEN=

# --- OAuth (set when using connect_bridge / complete_bridge_auth) ---
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=common
# BRIDGE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/bridge/oauth/callback
# GDRIVE_OAUTH_CLIENT_ID=
# GDRIVE_OAUTH_CLIENT_SECRET=
# DROPBOX_OAUTH_CLIENT_ID=

# --- Pools, TTL, GC ---
PG_MIN_POOL=1
PG_MAX_POOL=10
REDIS_MAX_CONNECTIONS=20
REDIS_TTL=3600
GC_INTERVAL_SECONDS=3600
GC_ORPHAN_AGE_SECONDS=300

# --- Quotas ---
TRIMCP_QUOTAS_ENABLED=true

# --- Cron (also set in deploy/compose.stack.env for containers) ---
BRIDGE_CRON_INTERVAL_MINUTES=45
BRIDGE_RENEWAL_LOOKAHEAD_HOURS=12

# --- Embedding batch ---
EMBED_BATCH_CHUNK=64

# --- In-process embedding backend (optional; default uses cognitive HTTP when URL set) ---
# TRIMCP_BACKEND=cpu

# --- Phase 1.2+ LLM keys (BYO) ---
# TRIMCP_OPENAI_API_KEY=
# TRIMCP_ANTHROPIC_API_KEY=
# (see trimcp/config.py for full list)

# --- Re-embedding worker (optional overrides) ---
# REEMBED_BATCH_SIZE=32
# REEMBED_BATCHES_PER_MINUTE=20
# REEMBED_CRON_INTERVAL_MINUTES=60

# --- Observability (OTLP + Prometheus) ---
TRIMCP_OBSERVABILITY_ENABLED=true
TRIMCP_PROMETHEUS_PORT=8000
TRIMCP_OTEL_SERVICE_NAME=trimcp-python
# When running via docker-compose, point to the Jaeger container:
TRIMCP_OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

# --- Jaeger UI ports (docker-compose only) ---
# JAEGER_UI_PORT=16686
# JAEGER_OTLP_HTTP_PORT=4318
