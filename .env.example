# ============================================================
# TriMCP Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- MongoDB ---
# Local Docker default:
MONGO_URI=mongodb://localhost:27017
# Production with auth:
# MONGO_URI=mongodb://user:password@host:27017/memory_archive?authSource=admin

# --- PostgreSQL + pgvector ---
# Local Docker default:
PG_DSN=postgresql://mcp_user:mcp_password@localhost:5432/memory_meta
# Production:
# PG_DSN=postgresql://user:password@host:5432/memory_meta?sslmode=require

# --- Redis ---
# Local Docker default:
REDIS_URL=redis://localhost:6379/0
# Production with TLS + auth:
# REDIS_URL=rediss://:password@host:6380/0

# --- Connection pool tuning ---
PG_MIN_POOL=1
PG_MAX_POOL=10
REDIS_MAX_CONNECTIONS=20

# --- Redis TTL (seconds) ---
REDIS_TTL=3600

# --- Embedding batch chunk size (caps RAM during large-file indexing) ---
EMBED_BATCH_CHUNK=64

# --- Embedding hardware (enterprise §8): cpu | cuda | rocm | xpu | openvino_npu | openvino | mps ---
# Leave empty for auto-detect (CUDA, ROCm, XPU, OpenVINO NPU, MPS, then CPU).
# TRIMCP_BACKEND=
# TRIMCP_OPENVINO_MODEL_DIR=
# TRIMCP_OPENVINO_SEQ_LEN=512

# --- Garbage Collector ---
GC_INTERVAL_SECONDS=3600
GC_ORPHAN_AGE_SECONDS=300
